pipeline {
    agent any

    stages {

        stage('docker build') {
            steps {
                dir('01-pipeline') {
                    bat "docker build -t velazalejandro/pagina_futbol:1.0.0-${env.BUILD_ID} ."
                }
            }
        }
        
        stage('docker login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat 'echo %PASS% | docker login -u %USER% --password-stdin'
                }
            }
        }

        stage('docker push') {
            steps {
                bat "docker push velazalejandro/pagina_futbol:1.0.0-${env.BUILD_ID}"
            }
        }

        stage('deploy') {
            steps {
                bat "docker stop pagina_futbol || true"
                bat "docker rm pagina_futbol || true"
                bat "docker run -d -p 3001:3000 --name pagina_futbol velazalejandro/pagina_futbol:1.0.0-${env.BUILD_ID}"
            }
        }

    }

        post {
        success {
            echo 'Despliegue completado con éxito!'
        }
        failure {
            echo 'La pipeline falló. Revisa los logs.'
        }
    }
}
