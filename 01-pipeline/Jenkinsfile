pipeline {
    agent any

    stages {
        stage('docker build') {
            steps {
              dir('01-pipeline') {
                bat "docker build -t velazalejandro/pagina_futbol:1.0.0-${env.BUILD_ID} ."
                }
            }   
        }
        
        stage('docker login') {
            steps {
		withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
		    bat 'echo $PASS | docker login -u $USER --password-stdin'
		}
    }
}
         stage('docker push') {
            steps {
               bat "docker push velazalejandro/pagina_futbol:1.0.0-${env.BUILD_ID}"
            }
        }
     }
 }
